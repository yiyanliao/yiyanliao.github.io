doctype html
html(lang=config.language)
    head
        meta(charset='UTF-8')
        meta(http-equiv="X-UA-Compatible" content="IE=edge")
        meta(name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5")
        meta(name="color-scheme" content="light dark")
        //- set theme before first paint to avoid a flash
        script.
            (function(){try{var t=localStorage.getItem('theme');if(!t){t=window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';}document.documentElement.setAttribute('data-theme',t);}catch(e){}})();
        - var pageTitle = (page.title && !is_home()) ? page.title + ' · ' + config.author : config.title
        - var pageDesc = page.description || config.description
        - var canonical = is_home() ? config.url + '/' : (page.permalink || full_url_for(page.path || '/'))
        - var ogImage = full_url_for(theme.avatar)
        title= pageTitle
        meta(name="author" content=config.author)
        meta(name="description" content=pageDesc)
        if config.keywords
            meta(name="keywords" content=config.keywords)
        link(rel="canonical" href=canonical)
        //- Open Graph (Facebook / LinkedIn / WeChat / Slack)
        meta(property="og:type" content=(is_home() ? 'profile' : 'website'))
        meta(property="og:site_name" content=config.title)
        meta(property="og:title" content=pageTitle)
        meta(property="og:description" content=pageDesc)
        meta(property="og:url" content=canonical)
        meta(property="og:image" content=ogImage)
        //- Twitter card (square headshot -> summary)
        meta(name="twitter:card" content="summary")
        meta(name="twitter:site" content="@Yiyan_Liao")
        meta(name="twitter:title" content=pageTitle)
        meta(name="twitter:description" content=pageDesc)
        meta(name="twitter:image" content=ogImage)
        !=favicon_tag(config.favicon || theme.favicon || '/favicon.ico')
        each item in theme.CDN_USE.css
            link(rel='stylesheet', href=url_for(item))
        if is_home()
            script(type="application/ld+json").
                {
                  "@context": "https://schema.org",
                  "@type": "Person",
                  "name": "Yiyan Liao",
                  "url": "#{config.url}",
                  "image": "#{ogImage}",
                  "jobTitle": "Undergraduate Researcher",
                  "affiliation": { "@type": "CollegeOrUniversity", "name": "Peking University" },
                  "sameAs": [
                    "https://scholar.google.com/citations?user=9DUJUoQAAAAJ&hl=en",
                    "https://orcid.org/0009-0000-5594-7013",
                    "https://github.com/yiyanliao",
                    "https://www.linkedin.com/in/yiyanliao/",
                    "https://x.com/Yiyan_Liao"
                  ]
                }
        if theme.cloudflare_token
            script(defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon=`{"token": "${theme.cloudflare_token}"}`)
    body
        header#page_header
            include ./header.pug
        main#page_main
            block content
        include ./mobile-nav.pug
        footer#page_footer
            include ./footer.pug
        each item in theme.CDN_USE.js
            script(src=url_for(item))